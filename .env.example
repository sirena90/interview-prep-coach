# Copy this file to .env and fill in your keys.
# DO NOT commit .env (it's in .gitignore).
#
# Settings are read by core/config.py (pydantic-settings). Variable names are
# case-insensitive.

# --- LLM provider -----------------------------------------------------------
# The provider is auto-detected from whichever key you set below.
# Set exactly ONE of these. If you set several, the priority is
# Anthropic > OpenAI > Mistral.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# Optional: override the default model per provider
# ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5-20250929
# OPENAI_DEFAULT_MODEL=gpt-4o
# MISTRAL_DEFAULT_MODEL=mistral-large-latest

# Optional: generation defaults
# DEFAULT_MAX_TOKENS=1024
# DEFAULT_TEMPERATURE=0.0

# --- Observability ----------------------------------------------------------
# LangSmith tracing (free tier — smith.langchain.com).
# Leave unset and the app still runs; tracing just becomes a no-op.
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=interview-prep-coach
